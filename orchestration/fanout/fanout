#!/usr/bin/env bash
# fanout — fan-out 工作流统一入口 (聚合各工具, 一个命令面)
#
#   fanout doctor              环境侦察 + 工作流推荐
#   fanout fleet status|up [--pty]|down  拉起/查看/停 ccb fleet (剥 CLAUDE_CODE_* + detached tmux; --pty=pty.fork 兜底)
#   fanout preflight [cfg]     运行前 go/no-go 门 (依赖/ccbd/no-Gemini/配置)
#   fanout task new|log|done   TASK 文件脚手架/日志/收尾
#   fanout template <n> [--set K=V]   渲染 prompt 模板 (impl|analysis|review)
#   fanout dispatch <agent> --template <n>|--prompt-file <f> [--task <file>]
#                              包 ccb ask: 渲 prompt → 派活 → 记日志
#   fanout cache ...           结果缓存 + fan-in barrier (init|put|fail|barrier|collect|resume|...)
#   fanout allocate <task-type> [--top]   按 bench 推荐模型 (code|logic|sql|chinese|...)
#   fanout workspace list|show|model|context <name>   工位上下文隔离 (借鉴 Zleap)
#   fanout experience add|list|recall|show <ws>   经验记忆: 完成→抽方法→脱敏存→复用
#   fanout plan "<goal>" [--models a,b,c]   多模型规划面板 (各自 Write 方案)
#   fanout goal template|show|check <spec>  目标模式: 声明式目标 + 确定性验收门
#   fanout summary <round> [--task <file>]   round 可观测汇总 (含耗时)
#   fanout ccb-sync check|adapt [--apply]    ccb 更新后同步适配 (版本/grafting/ccbd 重启)
#   fanout selftest            跑全部 *.test.sh
#   fanout help                本帮助
set -uo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

sub="${1:-help}"; shift || true
case "$sub" in
  doctor)    exec bash "$HERE/fanout-doctor.sh"    "$@";;
  preflight) exec bash "$HERE/fanout-preflight.sh" "$@";;
  fleet)     exec bash "$HERE/fanout-fleet.sh"     "$@";;
  task)      exec bash "$HERE/fanout-task.sh"      "$@";;
  template)  exec bash "$HERE/fanout-template.sh"  "$@";;
  dispatch)  exec bash "$HERE/fanout-dispatch.sh"  "$@";;
  cache)     exec bash "$HERE/fanout-cache.sh"     "$@";;
  allocate)  exec bash "$HERE/fanout-allocate.sh"  "$@";;
  workspace) exec bash "$HERE/fanout-workspace.sh" "$@";;
  experience) exec bash "$HERE/fanout-experience.sh" "$@";;
  plan)      exec bash "$HERE/fanout-plan.sh"      "$@";;
  goal)      exec bash "$HERE/fanout-goal.sh"      "$@";;
  summary|round-summary) exec bash "$HERE/fanout-summary.sh" "$@";;
  ccb-sync)  exec bash "$HERE/fanout-ccb-sync.sh" "$@";;
  selftest)
    ec=0
    for t in "$HERE"/*.test.sh; do
      [ -f "$t" ] || continue
      echo "── $(basename "$t") ──"
      bash "$t" || ec=1
    done
    [ "$ec" -eq 0 ] && echo "✓ selftest all passed" || echo "✗ selftest 有失败"
    exit "$ec";;
  help|-h|--help) sed -n '2,23p' "$0";;
  *) echo "fanout: 未知子命令 '$sub' (doctor|fleet|preflight|task|template|dispatch|cache|allocate|workspace|experience|plan|goal|summary|ccb-sync|selftest|help)" >&2; exit 2;;
esac
