# ccb.config.example — 脱敏模板
# ─────────────────────────────────────────────────────────────────────
# 用法: 拷到你项目根的 .ccb/ccb.config, 把 <...> 占位换成真 key。
#   cp orchestration/ccb/ccb.config.example /path/to/proj/.ccb/ccb.config
# 真 key 统一放在 ~/.config/cc-model-secrets.env (被 backends 的 launcher 读取);
# 这里的 key= 行只是给 ccb 直接 spawn 用, **绝不提交带真 key 的 ccb.config**
# (本仓 .gitignore 已忽略 **/.ccb/ccb.config, 只跟踪 .example)。
# ─────────────────────────────────────────────────────────────────────
version = 2
entry_window = "main"

[windows]
# planner = 你在战略层 (如 Claude Desktop app) 里直接 ccb ask (占位)
main   = "planner:claude"
# 实现层: 国产分身, 各自 worktree 隔离 (single source of truth = 主 branch)
work   = "cc-deepseek:claude(worktree), cc-glm:claude(worktree), cc-kimi:claude(worktree), cc-minimax:claude(worktree), cc-mimo:claude(worktree), cc-stepfun:claude(worktree)"
ark    = "cc-doubao:claude(worktree), cc-ark-auto:claude(worktree)"
# 审查层: Codex (gpt-5.5 frontier) —— 生成≠审查, 跨家独立第二意见
review = "coder:codex"

[ui.sidebar]
mode = "every_window"
width = "15%"
bottom_height = 20

[ui.sidebar.view]
agents_height = "50%"
comms_height  = "15%"
tips_height   = "35%"
comms_limit   = 3

[agents.planner]
description = "main pane 占位 (人是真 planner, 在战略层如 Claude Desktop app 里直接 ccb ask)"

[agents.cc-deepseek]
description = "DeepSeek V4-Pro 分身 (最新最强推理, 原生 Anthropic 端点)"
key = "<DEEPSEEK_API_KEY>"
url = "https://api.deepseek.com/anthropic"
model = "deepseek-v4-pro"
[agents.cc-deepseek.env]
CLAUDE_CODE_SIMPLE = "1"

[agents.cc-glm]
description = "智谱 GLM 5.2 分身 (最新, 原生 Anthropic 端点)"
key = "<GLM_API_KEY>"
url = "https://open.bigmodel.cn/api/anthropic"
model = "glm-5.2"
[agents.cc-glm.env]
CLAUDE_CODE_SIMPLE = "1"

[agents.cc-kimi]
description = "Moonshot Kimi For Coding 分身 (claude-cli UA 专用)"
key = "<KIMI_API_KEY>"
url = "https://api.kimi.com/coding"
model = "kimi-for-coding"
[agents.cc-kimi.env]
CLAUDE_CODE_SIMPLE = "1"

[agents.cc-minimax]
description = "MiniMax M3 分身 (最新 frontier, 原生 Anthropic 端点)"
key = "<MINIMAX_API_KEY>"
url = "https://api.minimaxi.com/anthropic"
model = "MiniMax-M3"
[agents.cc-minimax.env]
CLAUDE_CODE_SIMPLE = "1"

[agents.cc-mimo]
description = "小米 MiMo v2.5 Pro 分身 (原生 Anthropic 端点)"
key = "<MIMO_API_KEY>"
url = "https://token-plan-sgp.xiaomimimo.com/anthropic"
model = "mimo-v2.5-pro"
[agents.cc-mimo.env]
CLAUDE_CODE_SIMPLE = "1"

[agents.cc-stepfun]
description = "StepFun Step Plan 分身 (step-3.7-flash thinking)"
key = "<STEPFUN_API_KEY>"
url = "https://api.stepfun.com/step_plan"
model = "step-3.7-flash"
[agents.cc-stepfun.env]
CLAUDE_CODE_SIMPLE = "1"

# ─── 火山方舟 Coding Plan 聚合层 ──────────────────────────────
# 一个 ARK key 同时可用 8+ model: ark-code-latest / doubao-seed-code /
# deepseek-v4-flash / deepseek-v4-pro / kimi-k2.6 / glm-5.1 / minimax-latest
# 端点: https://ark.cn-beijing.volces.com/api/coding (不要用 /api/v3, 会扣额外费用)

[agents.cc-doubao]
description = "字节 Doubao Seed 2.0 编程版 (走火山方舟 Coding Plan)"
key = "<ARK_API_KEY>"
url = "https://ark.cn-beijing.volces.com/api/coding"
model = "doubao-seed-code-preview-latest"
[agents.cc-doubao.env]
CLAUDE_CODE_SIMPLE = "1"

[agents.cc-ark-auto]
description = "火山方舟 Coding Plan 自动切换 (控制台选 model, 3-5min 生效)"
key = "<ARK_API_KEY>"
url = "https://ark.cn-beijing.volces.com/api/coding"
model = "ark-code-latest"
[agents.cc-ark-auto.env]
CLAUDE_CODE_SIMPLE = "1"

[agents.coder]
description = "Codex CLI Reviewer/Implementer (gpt-5.5 frontier, ChatGPT 账号下最强)"
model = "gpt-5.5"
