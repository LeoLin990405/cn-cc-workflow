#!/usr/bin/env node
import { runSubcommandBridge } from "./fuguectl-node-bridge.mjs";

runSubcommandBridge({
  argv: process.argv.slice(2),
  command: "task",
  allowed: ["new", "log", "done"],
  help: `fuguectl-task — TypeScript TASK commands bridge

new  "<title>" [P0|P1|P2]
log  <task-file> "<message>"
done <task-file>
`,
  unknown: (subcommand) =>
    `fuguectl-task: unknown subcommand '${subcommand}' (new|log|done)`,
});
