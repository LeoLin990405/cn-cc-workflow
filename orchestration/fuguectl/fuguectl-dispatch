#!/usr/bin/env node
import { runSimpleBridge } from "./fuguectl-node-bridge.mjs";

runSimpleBridge({
  argv: process.argv.slice(2),
  command: "dispatch",
  helpOnEmpty: false,
  help: `fuguectl-dispatch <target> [--harness fugue-cc|codex|opencode|agy] [--timeout-ms n] [--codex-clean] [--harness-arg x] [--out <file>] [--require-output] [--verbose] [--workspace <ws> [--experience-query q] [--experience-source manual|task] [--experience-limit n] [--experience-trust trusted|all]] (--template <name> [--set K=V ...] | --prompt-file <f> | --prompt <text>) [--task <file>]
--task-type T  append (T, agent) into alloc ledger
--skills a,b   inject selected skills into that agent context
`,
});
