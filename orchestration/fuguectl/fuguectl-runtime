#!/usr/bin/env node
import { runSubcommandBridge } from "./fuguectl-node-bridge.mjs";

runSubcommandBridge({
  argv: process.argv.slice(2),
  command: "runtime",
  allowed: ["check", "adapt"],
  help: `fuguectl-runtime — TypeScript runtime sync bridge

check            print current/last provider version + drift
adapt [--apply]  verify grafting, optionally restart daemon, preflight, record version
`,
  unknown: (subcommand) =>
    `fuguectl-runtime: unknown subcommand '${subcommand}' (check|adapt)`,
});
