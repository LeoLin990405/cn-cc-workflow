#!/usr/bin/env node
import { runSubcommandBridge } from "./fuguectl-node-bridge.mjs";

runSubcommandBridge({
  argv: process.argv.slice(2),
  command: "goal",
  allowed: ["template", "show", "check"],
  help: `fuguectl-goal — TypeScript goal bridge

template          print spec template
show  <spec>      parse and display spec fields
check <spec>      run gate command
`,
  unknown: (subcommand) =>
    `fuguectl-goal: unknown subcommand '${subcommand}' (template|show|check)`,
});
