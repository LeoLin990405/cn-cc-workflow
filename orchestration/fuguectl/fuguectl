#!/usr/bin/env node
import { existsSync, readdirSync } from "node:fs";
import { basename, dirname, join } from "node:path";
import { fileURLToPath } from "node:url";
import { spawnSync } from "node:child_process";
import { runEngine } from "./fuguectl-node-bridge.mjs";

const here = dirname(fileURLToPath(import.meta.url));

const help = `fuguectl — fugue workflow control-plane entrypoint.

  fuguectl doctor              env recon + workflow recommendation
  fuguectl fleet status|up [--pty]|down  bring up/view/stop fugue-cc fleet
  fuguectl preflight [cfg]     pre-run go/no-go gate
  fuguectl task new|log|done   TASK file scaffold/log/finalize
  fuguectl template <n> [--set K=V]   render prompt template
  fuguectl dispatch <agent> --template <n>|--prompt-file <f> [--task <file>]
  fuguectl cache ...           result cache + join barrier
  fuguectl integrate --work <repo> --agents "a b" [--onconflict abort|skip]
  fuguectl allocate <task-type> [--top]|record|stats|reset
  fuguectl skills index|list|match|show|inject
  fuguectl workspace list|show|model|context <name>
  fuguectl agents template|validate|list|resolve
  fuguectl experience add|list|recall|show <ws>
  fuguectl plan "<goal>" [--models a,b,c]
  fuguectl goal template|show|check <spec>
  fuguectl loop init|record|decide|status
  fuguectl run set|round|status|next|clear
  fuguectl summary <round> [--task <file>]
  fuguectl runtime check|adapt [--apply]
  fuguectl selftest            run all *.test.sh / *.test.mjs
  fuguectl help                this help`;

const selftest = () => {
  let failed = false;
  for (const file of readdirSync(here).sort()) {
    if (!file.endsWith(".test.sh") && !file.endsWith(".test.mjs")) continue;
    const test = join(here, file);
    if (!existsSync(test)) continue;
    console.log(`── ${basename(test)} ──`);
    const command = file.endsWith(".test.mjs") ? process.execPath : "bash";
    const result = spawnSync(command, [test], { stdio: "inherit" });
    if (result.status !== 0) failed = true;
  }
  console.log(failed ? "✗ selftest had failures" : "✓ selftest all passed");
  process.exit(failed ? 1 : 0);
};

const args = process.argv.slice(2);
const [subcommand = "help", ...rest] = args;
const commandMap = new Map([
  ["doctor", "doctor"],
  ["preflight", "preflight"],
  ["fleet", "fleet"],
  ["task", "task"],
  ["template", "template"],
  ["dispatch", "dispatch"],
  ["cache", "cache"],
  ["integrate", "integrate"],
  ["allocate", "allocate"],
  ["skills", "skills"],
  ["workspace", "workspace"],
  ["agents", "agent-registry"],
  ["experience", "experience"],
  ["plan", "plan"],
  ["goal", "goal"],
  ["loop", "loop"],
  ["run", "run"],
  ["summary", "summary"],
  ["round-summary", "summary"],
  ["runtime", "runtime"],
]);

if (subcommand === "help" || subcommand === "-h" || subcommand === "--help") {
  console.log(help);
} else if (subcommand === "selftest") {
  selftest();
} else if (commandMap.has(subcommand)) {
  runEngine([commandMap.get(subcommand), ...rest]);
} else {
  console.error(
    `fuguectl: unknown subcommand '${subcommand}' (doctor|fleet|preflight|task|template|dispatch|cache|integrate|allocate|skills|workspace|agents|experience|plan|goal|loop|run|summary|runtime|selftest|help)`,
  );
  process.exit(2);
}
