{
  "name": "cn-cc-workflow",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "国产模型多 Agent 编码工作流: backends + fanout + ccb + bounded review-fix loop + auto-sync",
  "license": "Apache-2.0",
  "homepage": "https://github.com/LeoLin990405/cn-cc-workflow",
  "repository": {
    "type": "git",
    "url": "https://github.com/LeoLin990405/cn-cc-workflow.git"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "test:plugin": "node --check orchestration/cn-plugin/cn/scripts/cn-companion.mjs && node orchestration/cn-plugin/cn/scripts/cn-companion.test.mjs",
    "test:fanout": "bash orchestration/fanout/fanout selftest",
    "test": "npm run test:plugin && npm run test:fanout",
    "scan": "bash scripts/scan-secrets.sh",
    "lint:shell": "bash scripts/check-shell.sh",
    "ci": "npm run scan && npm run lint:shell && npm test"
  }
}
