# shellcheck 配置 — 本机 / CI / pre-commit 共用
#
# SC2034 (unused variable): 各 <provider>-code 启动器头部定义 MODELS / CC_OPUS /
#   CC_SONNET / CC_HAIKU / CC_FAST / CC_SUBAGENT / CC_MODEL_* 等, 由运行时 source
#   进来的 cc_model_launch()(在 cc-model-lib.sh)消费。shellcheck 做不到跨 source
#   的数据流分析, 会把它们全报成 "unused" —— 全是误报。
disable=SC2034
#
# SC1090/SC1091 (can't follow source): 启动器用动态路径 source cc-model-lib.sh,
#   静态分析跟不进去, 非缺陷。
disable=SC1090,SC1091
