#!/usr/bin/env bash
# Claude Code → MiMo Coding 分身
# 端点: MIMO_REGION 路由 (默认 sgp token-plan). 公共尾部见 cc_model_launch
# 注意: thinking 默认关 (服务端 thinking 块 signature 为空, 多轮中间件会拒)
REAL_HOME="$HOME"
source "$REAL_HOME/bin/cc-model-lib.sh"
export HOME="$REAL_HOME/.claude-envs/mimo"
mkdir -p "$HOME/.claude"
cc_model_unset_proxies

case "${MIMO_REGION:-sgp}" in
  cn)       MM_BURL="https://token-plan-cn.xiaomimimo.com/anthropic" ;;
  ams)      MM_BURL="https://token-plan-ams.xiaomimimo.com/anthropic" ;;
  public)   MM_BURL="https://api.mimo-v2.com/anthropic" ;;
  official) MM_BURL="https://api.xiaomimimo.com/anthropic" ;;
  sgp|*)    MM_BURL="https://token-plan-sgp.xiaomimimo.com/anthropic" ;;
esac
export ANTHROPIC_BASE_URL="${MIMO_BASE_URL:-$MM_BURL}"
export ANTHROPIC_AUTH_TOKEN="${MIMO_API_KEY:-${XIAOMI_API_KEY:-}}"
unset ANTHROPIC_API_KEY ANTHROPIC_API_BASE

# v2.5 默认开; MODELS 按 region/flags 变 (sgp token-plan 不收 mimo-v2-flash)
case "${MIMO_PROFILE:-}" in latest|v25|multimodal) MIMO_WANTS_V25=1 ;; *) MIMO_WANTS_V25="${MIMO_ENABLE_V25:-1}" ;; esac
case "${MIMO_REGION:-sgp}" in
  public) MODELS=(mimo-v2.5-pro mimo-v2.5 mimo-v2-pro mimo-v2-flash mimo-v2-omni); MM_FAST=mimo-v2-flash ;;
  *)
    if   [ "$MIMO_WANTS_V25" = "1" ] && [ "${MIMO_ENABLE_FLASH:-0}" = "1" ]; then MODELS=(mimo-v2.5-pro mimo-v2.5 mimo-v2-pro mimo-v2-flash mimo-v2-omni)
    elif [ "$MIMO_WANTS_V25" = "1" ]; then MODELS=(mimo-v2.5-pro mimo-v2.5 mimo-v2-pro mimo-v2-omni)
    elif [ "${MIMO_ENABLE_FLASH:-0}" = "1" ]; then MODELS=(mimo-v2-pro mimo-v2-flash mimo-v2-omni)
    else MODELS=(mimo-v2-pro mimo-v2-omni); fi
    MM_FAST=mimo-v2-pro ;;
esac
[[ "${1:-}" == "-l" || "${1:-}" == "--list" ]] && { printf '%s\n' "${MODELS[@]}"; exit 0; }

case "${MIMO_PROFILE:-pro}" in
  latest|v25) CC_DEF=mimo-v2.5-pro; CC_OPUS=mimo-v2.5-pro; CC_SONNET=mimo-v2.5-pro; CC_HAIKU=$MM_FAST ;;
  multimodal|omni)
    if [[ "${MIMO_REGION:-sgp}" == "public" || "${MIMO_ENABLE_V25:-0}" == "1" ]]; then CC_DEF=mimo-v2.5; CC_OPUS=mimo-v2.5-pro; CC_SONNET=mimo-v2.5
    else CC_DEF=mimo-v2-omni; CC_OPUS=mimo-v2-pro; CC_SONNET=mimo-v2-omni; fi
    CC_HAIKU=$MM_FAST ;;
  fast|flash) CC_DEF=$MM_FAST; CC_OPUS=mimo-v2-pro; CC_SONNET=$MM_FAST; CC_HAIKU=$MM_FAST ;;
  pro|*)      CC_DEF=mimo-v2.5-pro; CC_OPUS=mimo-v2.5-pro; CC_SONNET=mimo-v2.5; CC_HAIKU=$MM_FAST ;;
esac
MODEL="${MIMO_MODEL:-$CC_DEF}"
[[ "${1:-}" == "-m" || "${1:-}" == "--model" ]] && [[ -n "${2:-}" ]] && { MODEL="$2"; shift 2; }
CC_OPUS="${MIMO_OPUS:-$CC_OPUS}"; CC_SONNET="${MIMO_SONNET:-$CC_SONNET}"; CC_HAIKU="${MIMO_HAIKU:-$CC_HAIKU}"
CC_FAST="${MIMO_FAST:-$CC_HAIKU}"; CC_SUBAGENT="${MIMO_SUBAGENT:-$CC_SONNET}"

# ===== MiMo quirks =====
case "$MODEL" in *flash*) export CLAUDE_CODE_MAX_OUTPUT_TOKENS="${MIMO_MAX_OUTPUT:-64000}" ;; *) export CLAUDE_CODE_MAX_OUTPUT_TOKENS="${MIMO_MAX_OUTPUT:-128000}" ;; esac
export ANTHROPIC_BETAS=""; export DISABLE_PROMPT_CACHING="1"   # cache_control 不支持
if [ "${MIMO_ENABLE_THINKING:-0}" = "1" ] || [ -n "${MIMO_THINKING_BUDGET:-}" ]; then
  [ -n "$MIMO_THINKING_BUDGET" ] && export MAX_THINKING_TOKENS="$MIMO_THINKING_BUDGET"
else
  export MAX_THINKING_TOKENS=0 CLAUDE_CODE_DISABLE_THINKING=1 ANTHROPIC_THINKING=disabled
  export CLAUDE_CODE_EXTRA_BODY='{"thinking":{"type":"disabled"}}'; unset CLAUDE_CODE_ENABLE_THINKING
fi
[ -n "$MIMO_REASONING" ] && export CLAUDE_CODE_EFFORT_LEVEL="$MIMO_REASONING"
# 独有 header: safety / 内置搜索
MIMO_H=()
[ -n "$MIMO_SAFETY" ] && MIMO_H+=("x-mimo-safety: $MIMO_SAFETY")
[ "${MIMO_WEB_SEARCH:-0}" = "1" ] && MIMO_H+=("x-mimo-use-search: true")
[ ${#MIMO_H[@]} -gt 0 ] && { ANTHROPIC_CUSTOM_HEADERS="$(IFS=$'\n'; echo "${MIMO_H[*]}")"; export ANTHROPIC_CUSTOM_HEADERS; }

CC_MODEL_DISPLAY="MiMo Coding"
export CC_MODEL_COMMAND="cc-mimo" CC_MODEL_PROVIDER="mimo" CC_MODEL_PATCH_MARKER="MiMo Coding"
export CC_MODEL_PROMPT_FILE="$HOME/prompts/mimo-proactive-tools.md"
if [ -n "${MIMO_API_KEY:-}" ]; then export CC_MODEL_AUTH_LABEL="MIMO_API_KEY"; else export CC_MODEL_AUTH_LABEL="XIAOMI_API_KEY"; fi
export CC_MODEL_AUTH_VALUE="${MIMO_API_KEY:-${XIAOMI_API_KEY:-}}"
CC_MODEL_POST_HOOK="$REAL_HOME/bin/mimo-usage --update"   # 会话后更新本地 token 统计
cc_model_launch "$@"
