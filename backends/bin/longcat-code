#!/usr/bin/env bash
# LongCat Code — Claude Code → LongCat Anthropic-compatible API
# Endpoint: https://api.longcat.chat/anthropic. 公共尾部见 cc_model_launch
REAL_HOME="$HOME"
source "$REAL_HOME/bin/cc-model-lib.sh"
export HOME="$REAL_HOME/.claude-envs/longcat"
mkdir -p "$HOME/.claude"
cc_model_unset_proxies

# LONGCAT_API_KEY 常只在交互 shell; 空则兜底从登录 zsh 取
[ -z "${LONGCAT_API_KEY:-}" ] && LONGCAT_API_KEY="$(HOME="$REAL_HOME" zsh -lic 'printf %s "$LONGCAT_API_KEY"' 2>/dev/null || true)"
export ANTHROPIC_BASE_URL="https://api.longcat.chat/anthropic"
export ANTHROPIC_AUTH_TOKEN="${LONGCAT_API_KEY:-}"
unset ANTHROPIC_API_KEY ANTHROPIC_API_BASE

MODELS=(LongCat-2.0-Preview LongCat-Flash-Chat LongCat-Flash-Lite LongCat-Flash-Thinking LongCat-Flash-Thinking-2601)
[[ "${1:-}" == "-l" || "${1:-}" == "--list" ]] && { printf '%s\n' "${MODELS[@]}"; exit 0; }

case "${LONGCAT_PROFILE:-agent}" in
  fast|lite)   CC_DEF=LongCat-Flash-Lite;          CC_OPUS=LongCat-2.0-Preview;         CC_SONNET=LongCat-Flash-Lite;          CC_HAIKU=LongCat-Flash-Lite ;;
  stable|chat) CC_DEF=LongCat-Flash-Chat;          CC_OPUS=LongCat-2.0-Preview;         CC_SONNET=LongCat-Flash-Chat;          CC_HAIKU=LongCat-Flash-Lite ;;
  thinking)    CC_DEF=LongCat-Flash-Thinking-2601; CC_OPUS=LongCat-Flash-Thinking-2601; CC_SONNET=LongCat-Flash-Thinking-2601; CC_HAIKU=LongCat-Flash-Lite ;;
  agent|*)     CC_DEF=LongCat-2.0-Preview;         CC_OPUS=LongCat-2.0-Preview;         CC_SONNET=LongCat-2.0-Preview;         CC_HAIKU=LongCat-Flash-Lite ;;
esac
MODEL="${LONGCAT_MODEL:-$CC_DEF}"
[[ "${1:-}" == "-m" || "${1:-}" == "--model" ]] && [[ -n "${2:-}" ]] && { MODEL="$2"; shift 2; }
CC_OPUS="${LONGCAT_OPUS:-$CC_OPUS}"; CC_SONNET="${LONGCAT_SONNET:-$CC_SONNET}"; CC_HAIKU="${LONGCAT_HAIKU:-$CC_HAIKU}"
CC_FAST="${LONGCAT_FAST:-$CC_HAIKU}"; CC_SUBAGENT="${LONGCAT_SUBAGENT:-$CC_SONNET}"

# ===== LongCat quirks =====
# 文档无 Claude extended-thinking; 默认关 (profile=thinking 或 LONGCAT_ENABLE_THINKING 时不关)
if [[ -z "${LONGCAT_ENABLE_THINKING:-}" && "${LONGCAT_PROFILE:-agent}" != "thinking" ]]; then
  export MAX_THINKING_TOKENS=0 CLAUDE_CODE_DISABLE_THINKING=1 ANTHROPIC_THINKING=disabled
fi
export DISABLE_PROMPT_CACHING=1
export API_TIMEOUT_MS="${LONGCAT_API_TIMEOUT_MS:-3000000}"
case "$MODEL" in
  LongCat-2.0-Preview) LC_MAX=64000 ;;
  LongCat-Flash-Chat)  LC_MAX=131072 ;;
  *)                   LC_MAX=262144 ;;
esac
export CLAUDE_CODE_MAX_OUTPUT_TOKENS="${LONGCAT_MAX_OUTPUT:-$LC_MAX}"

CC_MODEL_DISPLAY="LongCat Code"
export CC_MODEL_COMMAND="cc-longcat" CC_MODEL_PROVIDER="longcat" CC_MODEL_PATCH_MARKER="LongCat Code"
export CC_MODEL_PROMPT_FILE="$HOME/prompts/longcat-proactive-tools.md"
export CC_MODEL_AUTH_LABEL="LONGCAT_API_KEY" CC_MODEL_AUTH_VALUE="$ANTHROPIC_AUTH_TOKEN"
cc_model_launch "$@"
