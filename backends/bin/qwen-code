#!/usr/bin/env bash
# Claude Code → Qwen Coding 分身
# 端点: DashScope/Coding-Plan/Token-Plan Anthropic 兼容, 按 QWEN_PROFILE 路由
# 模型: qwen3-coder-plus/next/flash/480b + 3.7-max/plus + 3.6/3.5 系. 公共尾部见 cc_model_launch
REAL_HOME="$HOME"
source "$REAL_HOME/bin/cc-model-lib.sh"
export HOME="$REAL_HOME/.claude-envs/qwen"
mkdir -p "$HOME/.claude"
cc_model_unset_proxies

export ANTHROPIC_AUTH_TOKEN="${DASHSCOPE_API_KEY:-${QWEN_API_KEY:-${BAILIAN_API_KEY:-}}}"
unset ANTHROPIC_API_KEY ANTHROPIC_API_BASE

MODELS=(qwen3-coder-plus qwen3-coder-next qwen3-coder-flash qwen3-coder-480b-a35b-instruct qwen3.7-max qwen3.7-plus qwen3.6-plus qwen3.6-flash qwen3.5-plus qwen3.5-flash qwen3-max qwen3-235b-a22b-instruct-2507 qwen3-30b-a3b-instruct-2507)
[[ "${1:-}" == "-l" || "${1:-}" == "--list" ]] && { printf '%s\n' "${MODELS[@]}"; exit 0; }

case "${QWEN_PROFILE:-coder}" in
  coding|coding-plan|plan) QWEN_BURL="https://coding-intl.dashscope.aliyuncs.com/apps/anthropic"; CC_DEF=qwen3.6-plus;       CC_OPUS=qwen3.6-plus;     CC_SONNET=qwen3.6-plus;     CC_HAIKU=qwen3.6-plus ;;
  token|token-plan|team)   QWEN_BURL="https://token-plan.ap-southeast-1.maas.aliyuncs.com/apps/anthropic"; CC_DEF=qwen3.7-max; CC_OPUS=qwen3.7-max; CC_SONNET=qwen3.7-max; CC_HAIKU=qwen3.6-flash ;;
  max|payg|intl)           QWEN_BURL="https://dashscope-intl.aliyuncs.com/apps/anthropic"; CC_DEF=qwen3.7-max;        CC_OPUS=qwen3.7-max;      CC_SONNET=qwen3.7-max;      CC_HAIKU=qwen3.6-flash ;;
  cheap|flash)             QWEN_BURL="https://dashscope.aliyuncs.com/apps/anthropic"; CC_DEF=qwen3-coder-flash;  CC_OPUS=qwen3-coder-next; CC_SONNET=qwen3-coder-flash; CC_HAIKU=qwen3-coder-flash ;;
  coder|*)                 QWEN_BURL="https://dashscope.aliyuncs.com/apps/anthropic"; CC_DEF=qwen3-coder-next;   CC_OPUS=qwen3-coder-plus; CC_SONNET=qwen3-coder-next;  CC_HAIKU=qwen3-coder-flash ;;
esac
export ANTHROPIC_BASE_URL="${QWEN_BASE_URL:-$QWEN_BURL}"
MODEL="${QWEN_MODEL:-$CC_DEF}"
[[ "${1:-}" == "-m" || "${1:-}" == "--model" ]] && [[ -n "${2:-}" ]] && { MODEL="$2"; shift 2; }
CC_OPUS="${QWEN_OPUS:-$CC_OPUS}"; CC_SONNET="${QWEN_SONNET:-$CC_SONNET}"; CC_HAIKU="${QWEN_HAIKU:-$CC_HAIKU}"
CC_FAST="${QWEN_FAST:-$CC_HAIKU}"; CC_SUBAGENT="${QWEN_SUBAGENT:-$CC_SONNET}"

# ===== Qwen quirks =====
export CLAUDE_CODE_MAX_OUTPUT_TOKENS="${QWEN_MAX_OUTPUT:-65536}"
case "${QWEN_ENABLE_THINKING:-}" in
  1|true|enabled)   export CLAUDE_CODE_EXTRA_BODY='{"enable_thinking":true}' ;;
  0|false|disabled) export CLAUDE_CODE_EXTRA_BODY='{"enable_thinking":false}' ;;
esac

CC_MODEL_DISPLAY="Qwen Coding"
export CC_MODEL_COMMAND="cc-qwen" CC_MODEL_PROVIDER="qwen" CC_MODEL_PATCH_MARKER="Qwen Coding"
export CC_MODEL_PROMPT_FILE="$HOME/prompts/qwen-proactive-tools.md"
export CC_MODEL_AUTH_LABEL="DASHSCOPE_API_KEY/QWEN_API_KEY/BAILIAN_API_KEY" CC_MODEL_AUTH_VALUE="$ANTHROPIC_AUTH_TOKEN"
cc_model_launch "$@"
