#!/usr/bin/env bash
# Claude Code → Doubao Coding 分身
# 端点: https://ark.cn-beijing.volces.com/api/coding (火山方舟 Coding Plan)
# 模型: Doubao Seed Code + ark-code-latest 路由 + Seed 2.0 系. 公共尾部见 cc_model_launch
REAL_HOME="$HOME"
source "$REAL_HOME/bin/cc-model-lib.sh"
export HOME="$REAL_HOME/.claude-envs/doubao"
mkdir -p "$HOME/.claude"
cc_model_unset_proxies

export ANTHROPIC_BASE_URL="https://ark.cn-beijing.volces.com/api/coding"
export ANTHROPIC_AUTH_TOKEN="${ARK_API_KEY:-${VOLC_API_KEY:-${DOUBAO_API_KEY:-}}}"
unset ANTHROPIC_API_KEY ANTHROPIC_API_BASE

MODELS=(doubao-seed-code-preview-latest doubao-seed-code-preview-251028 ark-code-latest doubao-seed-2.0-code doubao-seed-2.0-pro doubao-seed-2.0-lite doubao-seed-code)
[[ "${1:-}" == "-l" || "${1:-}" == "--list" ]] && { printf '%s\n' "${MODELS[@]}"; exit 0; }

case "${DOUBAO_PROFILE:-latest}" in
  agent)            CC_DEF=doubao-seed-code-preview-latest; CC_OPUS=doubao-seed-code-preview-latest; CC_SONNET=doubao-seed-code-preview-latest; CC_HAIKU=doubao-seed-2.0-lite ;;
  vision|frontend)  CC_DEF=doubao-seed-code-preview-latest; CC_OPUS=doubao-seed-code-preview-latest; CC_SONNET=doubao-seed-code-preview-latest; CC_HAIKU=doubao-seed-code-preview-latest ;;
  pinned)           CC_DEF=doubao-seed-code-preview-251028; CC_OPUS=doubao-seed-code-preview-251028; CC_SONNET=doubao-seed-code-preview-251028; CC_HAIKU=doubao-seed-code-preview-251028 ;;
  router)           CC_DEF=ark-code-latest;                 CC_OPUS=ark-code-latest;                 CC_SONNET=ark-code-latest;                 CC_HAIKU=doubao-seed-2.0-lite ;;
  cheap)            CC_DEF=doubao-seed-2.0-lite;             CC_OPUS=doubao-seed-2.0-lite;             CC_SONNET=doubao-seed-2.0-lite;             CC_HAIKU=doubao-seed-2.0-lite ;;
  seed20|reasoning) CC_DEF=doubao-seed-2.0-code;             CC_OPUS=doubao-seed-2.0-code;             CC_SONNET=doubao-seed-2.0-code;             CC_HAIKU=doubao-seed-2.0-lite ;;
  latest|*)         CC_DEF=doubao-seed-code-preview-latest; CC_OPUS=doubao-seed-code-preview-latest; CC_SONNET=doubao-seed-2.0-pro;              CC_HAIKU=doubao-seed-2.0-lite ;;
esac
MODEL="${DOUBAO_MODEL:-$CC_DEF}"
[[ "${1:-}" == "-m" || "${1:-}" == "--model" ]] && [[ -n "${2:-}" ]] && { MODEL="$2"; shift 2; }
CC_OPUS="${DOUBAO_OPUS:-$CC_OPUS}"; CC_SONNET="${DOUBAO_SONNET:-$CC_SONNET}"; CC_HAIKU="${DOUBAO_HAIKU:-$CC_HAIKU}"
CC_FAST="${DOUBAO_FAST:-$CC_HAIKU}"; CC_SUBAGENT="${DOUBAO_SUBAGENT:-$CC_SONNET}"

# ===== Doubao quirks =====
case "$MODEL" in
  *lite|*pro|ark-code-latest) export CLAUDE_CODE_MAX_OUTPUT_TOKENS="${DOUBAO_MAX_OUTPUT:-131072}" ;;
  *)                          export CLAUDE_CODE_MAX_OUTPUT_TOKENS="${DOUBAO_MAX_OUTPUT:-32768}" ;;
esac
[ -n "$DOUBAO_REASONING" ] && export CLAUDE_CODE_EFFORT_LEVEL="$DOUBAO_REASONING"
# seed-code 老模型不认 reasoning_effort; ark-code-latest 默认带 unsigned thinking → 默认关 thinking
DB_EB=""; DB_SEP=""
if [ "${DOUBAO_ENABLE_THINKING:-0}" != "1" ]; then
  export MAX_THINKING_TOKENS=0 CLAUDE_CODE_DISABLE_THINKING=1 ANTHROPIC_THINKING=disabled
  unset CLAUDE_CODE_EFFORT_LEVEL
  DB_EB="\"thinking\":{\"type\":\"disabled\"}"; DB_SEP=","
fi
if [ -n "${DOUBAO_MAX_COMPLETION_TOKENS:-}" ] && [[ "$DOUBAO_MAX_COMPLETION_TOKENS" =~ ^[0-9]+$ ]]; then
  DB_EB="${DB_EB}${DB_SEP}\"max_completion_tokens\":${DOUBAO_MAX_COMPLETION_TOKENS}"; DB_SEP=","
elif [ "${DOUBAO_COMPLETION_BUDGET:-}" = "full" ]; then
  DB_EB="${DB_EB}${DB_SEP}\"max_completion_tokens\":64000"; DB_SEP=","
fi
[ -n "$DB_EB" ] && export CLAUDE_CODE_EXTRA_BODY="{$DB_EB}"

CC_MODEL_DISPLAY="Doubao Coding"
export CC_MODEL_COMMAND="cc-doubao" CC_MODEL_PROVIDER="doubao" CC_MODEL_PATCH_MARKER="Doubao Coding"
export CC_MODEL_PROMPT_FILE="$HOME/prompts/doubao-proactive-tools.md"
export CC_MODEL_AUTH_LABEL="ARK_API_KEY/VOLC_API_KEY/DOUBAO_API_KEY" CC_MODEL_AUTH_VALUE="$ANTHROPIC_AUTH_TOKEN"
cc_model_launch "$@"
