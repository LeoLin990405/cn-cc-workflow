#!/usr/bin/env bash
# Claude Code → GLM Coding 分身
# 端点: https://api.z.ai/api/anthropic (Anthropic 兼容; GLM_BASE_URL 可覆盖)
# 模型: glm-5.2/5.1/5-turbo/5/4.7/4.6/4.5/4.5-air. 公共尾部见 cc-model-lib.sh: cc_model_launch
REAL_HOME="$HOME"
source "$REAL_HOME/bin/cc-model-lib.sh"
export HOME="$REAL_HOME/.claude-envs/glm"
mkdir -p "$HOME/.claude"
cc_model_unset_proxies

export ANTHROPIC_BASE_URL="${GLM_BASE_URL:-https://api.z.ai/api/anthropic}"
export ANTHROPIC_AUTH_TOKEN="${GLM_API_KEY:-${ZAI_API_KEY:-${BIGMODEL_API_KEY:-}}}"
unset ANTHROPIC_API_KEY ANTHROPIC_API_BASE

MODELS=(glm-5.2 glm-5.1 glm-5-turbo glm-5 glm-4.7 glm-4.6 glm-4.5 glm-4.5-air)
[[ "${1:-}" == "-l" || "${1:-}" == "--list" ]] && { printf '%s\n' "${MODELS[@]}"; exit 0; }

case "${GLM_PROFILE:-balanced}" in
  max|opus)   CC_DEF=glm-5.2;      CC_OPUS=glm-5.2; CC_SONNET=glm-5.2;     CC_HAIKU=glm-4.5-air ;;
  turbo)      CC_DEF=glm-5-turbo;  CC_OPUS=glm-5.2; CC_SONNET=glm-5-turbo; CC_HAIKU=glm-4.5-air ;;
  cheap|lite) CC_DEF=glm-4.5-air;  CC_OPUS=glm-4.7; CC_SONNET=glm-4.7;     CC_HAIKU=glm-4.5-air ;;
  balanced|*) CC_DEF=glm-5.2;      CC_OPUS=glm-5.2; CC_SONNET=glm-5.1;     CC_HAIKU=glm-5-turbo ;;
esac
MODEL="${GLM_MODEL:-$CC_DEF}"
[[ "${1:-}" == "-m" || "${1:-}" == "--model" ]] && [[ -n "${2:-}" ]] && { MODEL="$2"; shift 2; }
[[ "$MODEL" != glm-* ]] && MODEL="glm-$MODEL"
CC_OPUS="${GLM_OPUS:-$CC_OPUS}"; CC_SONNET="${GLM_SONNET:-$CC_SONNET}"; CC_HAIKU="${GLM_HAIKU:-$CC_HAIKU}"
CC_FAST="${GLM_FAST:-$CC_HAIKU}"; CC_SUBAGENT="${GLM_SUBAGENT:-glm-4.5-air}"

# ===== GLM quirks =====
export CLAUDE_CODE_MAX_OUTPUT_TOKENS="${GLM_MAX_OUTPUT:-128000}"  # 官方 output 上限 128K
export CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS="1"
[ -n "$GLM_THINKING_BUDGET" ] && export MAX_THINKING_TOKENS="$GLM_THINKING_BUDGET"
GLM_EB=""; GLM_SEP=""
case "${GLM_THINKING:-auto}" in
  1|true|enabled)   GLM_EB="\"thinking\":{\"type\":\"enabled\"}";  GLM_SEP="," ;;
  0|false|disabled) GLM_EB="\"thinking\":{\"type\":\"disabled\"}"; GLM_SEP="," ;;
  auto) case "${GLM_PROFILE:-balanced}" in max|opus|turbo) GLM_EB="\"thinking\":{\"type\":\"enabled\"}"; GLM_SEP="," ;; esac ;;
esac
[ "${GLM_DO_SAMPLE:-}" = "false" ] && { GLM_EB="${GLM_EB}${GLM_SEP}\"do_sample\":false"; GLM_SEP=","; }
[ -n "$GLM_EB" ] && export CLAUDE_CODE_EXTRA_BODY="{$GLM_EB}"

# ===== meta + 启动 =====
CC_MODEL_DISPLAY="GLM Coding"
export CC_MODEL_COMMAND="cc-glm" CC_MODEL_PROVIDER="glm" CC_MODEL_PATCH_MARKER="GLM Coding"
export CC_MODEL_PROMPT_FILE="$HOME/prompts/glm-proactive-tools.md"
export CC_MODEL_AUTH_LABEL="GLM_API_KEY/ZAI_API_KEY/BIGMODEL_API_KEY" CC_MODEL_AUTH_VALUE="$ANTHROPIC_AUTH_TOKEN"
cc_model_launch "$@"
