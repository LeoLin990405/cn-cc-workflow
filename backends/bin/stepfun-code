#!/usr/bin/env bash
# Claude Code → Step Coding 分身
# 端点: https://api.stepfun.com/step_plan (.com; .ai 域名会 401)
# 模型: step-3.7-flash(旗舰)/3.5-flash-2603/3.5-flash/router-v1. 公共尾部见 cc_model_launch
REAL_HOME="$HOME"
source "$REAL_HOME/bin/cc-model-lib.sh"
export HOME="$REAL_HOME/.claude-envs/stepfun"
mkdir -p "$HOME/.claude"
cc_model_unset_proxies

export ANTHROPIC_BASE_URL="${STEPFUN_BASE_URL:-https://api.stepfun.com/step_plan}"
export ANTHROPIC_AUTH_TOKEN="${STEPFUN_API_KEY:-${STEP_API_KEY:-}}"
unset ANTHROPIC_API_KEY ANTHROPIC_API_BASE

MODELS=(step-3.7-flash step-3.5-flash-2603 step-3.5-flash step-router-v1)
[[ "${1:-}" == "-l" || "${1:-}" == "--list" ]] && { printf '%s\n' "${MODELS[@]}"; exit 0; }

case "${STEPFUN_PROFILE:-reasoning}" in
  router)      CC_DEF=step-router-v1; CC_OPUS=step-router-v1;      CC_SONNET=step-router-v1;      CC_HAIKU=step-3.5-flash ;;
  fast|flash)  CC_DEF=step-3.5-flash; CC_OPUS=step-3.5-flash-2603; CC_SONNET=step-3.5-flash;      CC_HAIKU=step-3.5-flash ;;
  reasoning|*) CC_DEF=step-3.7-flash; CC_OPUS=step-3.7-flash;      CC_SONNET=step-3.5-flash-2603; CC_HAIKU=step-3.5-flash ;;
esac
MODEL="${STEPFUN_MODEL:-$CC_DEF}"
[[ "${1:-}" == "-m" || "${1:-}" == "--model" ]] && [[ -n "${2:-}" ]] && { MODEL="$2"; shift 2; }
CC_OPUS="${STEPFUN_OPUS:-$CC_OPUS}"; CC_SONNET="${STEPFUN_SONNET:-$CC_SONNET}"; CC_HAIKU="${STEPFUN_HAIKU:-$CC_HAIKU}"
CC_FAST="${STEPFUN_FAST:-$CC_HAIKU}"; CC_SUBAGENT="${STEPFUN_SUBAGENT:-$CC_SONNET}"

# ===== Step quirks =====
export CLAUDE_CODE_MAX_OUTPUT_TOKENS="${STEPFUN_MAX_OUTPUT:-65536}"
case "${STEPFUN_REASONING:-}" in
  low|high)
    export CLAUDE_CODE_EFFORT_LEVEL="$STEPFUN_REASONING"
    if [[ "$MODEL" == "step-3.5-flash-2603" || "${STEPFUN_FORCE_EFFORT:-0}" == "1" ]]; then
      export CLAUDE_CODE_EXTRA_BODY="{\"output_config\":{\"effort\":\"$STEPFUN_REASONING\"}}"
    else
      echo "[cc-stepfun] ⚠️  output_config.effort 仅 step-3.5-flash-2603 生效; 当前 $MODEL 不注入" >&2
    fi ;;
  none)
    export MAX_THINKING_TOKENS=0 CLAUDE_CODE_DISABLE_THINKING=1 CLAUDE_CODE_EFFORT_LEVEL=none
    export CLAUDE_CODE_EXTRA_BODY='{"thinking":{"type":"disabled"}}' ;;
  "") ;;
  *) echo "[cc-stepfun] ⚠️  STEPFUN_REASONING 只支持 low/high/none" >&2 ;;
esac
if [ "${STEPFUN_NO_THINKING:-0}" = "1" ]; then
  export MAX_THINKING_TOKENS=0 CLAUDE_CODE_DISABLE_THINKING=1 CLAUDE_CODE_EFFORT_LEVEL=none
  export CLAUDE_CODE_EXTRA_BODY='{"thinking":{"type":"disabled"}}'
fi
# 已知 quirk: stepfun 响应 resp.model 为空字符串, 不影响 text/tool_use/多轮功能

CC_MODEL_DISPLAY="Step Coding"
export CC_MODEL_COMMAND="cc-stepfun" CC_MODEL_PROVIDER="stepfun" CC_MODEL_PATCH_MARKER="Step Coding"
export CC_MODEL_PROMPT_FILE="$HOME/prompts/stepfun-proactive-tools.md"
export CC_MODEL_AUTH_LABEL="STEPFUN_API_KEY/STEP_API_KEY" CC_MODEL_AUTH_VALUE="$ANTHROPIC_AUTH_TOKEN"
cc_model_launch "$@"
